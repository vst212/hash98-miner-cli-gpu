# ============================================================================
#  hash98-miner — example .env  (copy to .env and fill in)
# ----------------------------------------------------------------------------
#  start.bat will guide you through creating this file on first run if it is
#  missing. Values set here override matching keys in `miner.toml`.
# ============================================================================

# --- WALLET KEYS (CHOOSE ONE) -----------------------------------------------
# A. Single key — paste the 0x-prefixed 32-byte private key here:
HASH98_PRIVATE_KEY=

# B. (or) point to a file with one hex private key per line:
HASH98_KEYS_FILE=keys.txt

# --- RPC --------------------------------------------------------------------
# Default works (publicnode); replace with your own Alchemy/Infura/QuickNode
# endpoint for higher rate limits.
HASH98_RPC_URL=https://ethereum-rpc.publicnode.com

# Comma-separated fallbacks; rotated automatically on RPC errors.
HASH98_RPC_FALLBACKS=https://eth.llamarpc.com,https://rpc.ankr.com/eth,https://eth.drpc.org

# Optional WebSocket for newHeads subscription (else: HTTP polling).
HASH98_WS_URL=

# --- GPU --------------------------------------------------------------------
# "all" or comma-separated flat indices from `hashminer devices`.
HASH98_GPU_DEVICES=all

# Kernel SHA-256 unroll: compact | full | auto | <int>
#   compact -> -D SHA256_UNROLL=1   (often fastest on Ampere/RTX 30xx)
#   full    -> -D SHA256_UNROLL=64  (often fastest on Ada/Blackwell)
HASH98_UNROLL=compact

# OpenCL local work group size (try 64 / 128 / 256 — bench it).
HASH98_LOCAL_SIZE=64

# --- BEHAVIOUR --------------------------------------------------------------
HASH98_DRY_RUN=false
HASH98_LOG_LEVEL=INFO
